{
  "name": "zspark-desktop",
  "version": "0.0.2",
  "description": "Codex-powered desktop client for local and shared agent workspaces.",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/build-gmail-mcp.mjs && electron-vite build",
    "test": "vitest run",
    "extract-icons": "powershell -ExecutionPolicy Bypass -File scripts/extract_icons.ps1",
    "build:win": "pnpm run extract-icons && node scripts/build-win.mjs",
    "build:mac": "node scripts/build-gmail-mcp.mjs && electron-vite build && electron-builder --mac dmg",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.1",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.2",
    "electron-store": "^10.0.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "marked": "^14.1.4",
    "mermaid": "^11.15.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.18",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.zspark.desktop",
    "productName": "zspark",
    "afterPack": "./scripts/afterPack.js",
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "../codex-rs/target/release",
        "to": "bin",
        "filter": [
          "codex",
          "codex.exe",
          "codex-windows-sandbox-setup.exe",
          "codex-command-runner.exe"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "gmail-mcp-server.mjs",
          "gmail-oauth-bootstrap.mjs"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis",
      "artifactName": "zspark-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "leveldown"
    ]
  }
}
